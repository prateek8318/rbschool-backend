{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "outDir": "dist",
    "baseUrl": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "paths": {
      "@rbschool/shared": [
        "../../packages/shared/src"
      ]
    },
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*",
    "server.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
